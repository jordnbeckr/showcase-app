generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Studio {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  slug         String        @unique
  passwordHash String
  order        Int           @default(0)
  instructors  Instructor[]
  students     Student[]
  proShows     ProShow[]
  studentShows StudentShow[]
  studioBudget StudioBudget?
}

model Instructor {
  id            Int            @id @default(autoincrement())
  name          String
  studioId      Int
  studio        Studio         @relation(fields: [studioId], references: [id], onDelete: Cascade)
  heatEntries   HeatEntry[]
  role          String         @default("Neither")
  leaderNumber  Int?
  studentEvents StudentEvent[]
  studentShows  StudentShow[]  @relation("StudentShowInstructors")
}

model DanceType {
  id    Int    @id @default(autoincrement())
  name  String @unique
  order Int    @default(0)
  heats Heat[]
}

model Event {
  id             Int            @id @default(autoincrement())
  name           String
  order          Int            @default(0)
  isAmateur      Boolean        @default(false)
  isCompetitive  Boolean        @default(false)
  heats          EventHeat[]
  studentEvents  StudentEvent[]
  compRound      CompRound?
  compScores     CompScore[]
  semiMarks      SemiMark[]
}

model StudentEvent {
  id               Int        @id @default(autoincrement())
  studentId        Int
  eventId          Int
  instructorId     Int?
  partnerStudentId Int?
  student          Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  event            Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  instructor       Instructor? @relation(fields: [instructorId], references: [id], onDelete: SetNull)

  @@unique([studentId, eventId])
}

model EventHeat {
  eventId Int
  heatId  Int
  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  heat    Heat  @relation(fields: [heatId], references: [id], onDelete: Cascade)

  @@id([eventId, heatId])
}

model Heat {
  id           Int          @id @default(autoincrement())
  number       Int          @unique
  danceTypeId  Int
  danceType    DanceType    @relation(fields: [danceTypeId], references: [id], onDelete: Cascade)
  maxCapacity  Int          @default(24)
  category     String       @default("none") // "none" | "closed" | "open"
  entries      HeatEntry[]
  events       EventHeat[]
  closedScores ClosedScore[]
  openThumbs   OpenThumb[]
  openNotes    OpenNote[]
}

model Student {
  id              Int            @id @default(autoincrement())
  firstName       String
  lastName        String
  role            String
  studioId        Int
  studio          Studio         @relation(fields: [studioId], references: [id], onDelete: Cascade)
  heatEntries     HeatEntry[]    @relation("HeatEntryStudent")
  partnerEntries  HeatEntry[]    @relation("HeatEntryPartner")
  studentShows    StudentShow[]  @relation("StudentShowStudents")
  leaderNumber    Int?
  checkedIn       Boolean        @default(false)
  studentEvents   StudentEvent[]
  closedScores    ClosedScore[]
  openThumbs      OpenThumb[]
  openNotes       OpenNote[]
  compScores      CompScore[]
  semiMarks       SemiMark[]
}

model BudgetItem {
  id       Int    @id @default(autoincrement())
  name     String
  category String  // "participation" | "attendee"
  unitCost Float
  quantity Int    @default(1)
  order    Int    @default(0)
}

model ShowcaseSettings {
  id       Int   @id @default(autoincrement())
  entryFee Float @default(0)
}

model StudioBudget {
  id        Int     @id @default(autoincrement())
  studioId  Int     @unique
  studio    Studio  @relation(fields: [studioId], references: [id], onDelete: Cascade)
  attendees Int     @default(0)
  paid      Boolean @default(false)
}

model HeatEntry {
  id               Int        @id @default(autoincrement())
  heatId           Int
  heat             Heat       @relation(fields: [heatId], references: [id], onDelete: Cascade)
  studentId        Int
  student          Student    @relation("HeatEntryStudent", fields: [studentId], references: [id], onDelete: Cascade)
  instructorId     Int?
  instructor       Instructor? @relation(fields: [instructorId], references: [id], onDelete: SetNull)
  partnerStudentId Int?
  partnerStudent   Student?   @relation("HeatEntryPartner", fields: [partnerStudentId], references: [id], onDelete: SetNull)
  createdAt        DateTime   @default(now())

  @@unique([heatId, studentId])
}

model ProShow {
  id          Int      @id @default(autoincrement())
  studioId    Int
  studio      Studio   @relation(fields: [studioId], references: [id], onDelete: Cascade)
  partnership String
  dances      String
  songTitle   String?
  artist      String?
  musicLink   String?
  notes       String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}

model StudentShow {
  id           Int          @id @default(autoincrement())
  studioId     Int
  studio       Studio       @relation(fields: [studioId], references: [id], onDelete: Cascade)
  students     Student[]    @relation("StudentShowStudents")
  instructors  Instructor[] @relation("StudentShowInstructors")
  dances       String
  songTitle    String?
  artist       String?
  musicLink    String?
  notes        String?
  order        Int          @default(0)
  createdAt    DateTime     @default(now())
}

model Judge {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  pinHash      String
  closedScores ClosedScore[]
  openThumbs   OpenThumb[]
  openNotes    OpenNote[]
  compScores   CompScore[]
  semiMarks    SemiMark[]
}

model FeedbackCategory {
  id         Int         @id @default(autoincrement())
  name       String      @unique
  order      Int         @default(0)
  openThumbs OpenThumb[]
}

// Closed heat: Gold/Silver/Bronze per judge × student × heat
model ClosedScore {
  id        Int     @id @default(autoincrement())
  judgeId   Int
  judge     Judge   @relation(fields: [judgeId], references: [id], onDelete: Cascade)
  heatId    Int
  heat      Heat    @relation(fields: [heatId], references: [id], onDelete: Cascade)
  studentId Int
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  placement String  // "Gold" | "Silver" | "Bronze"

  @@unique([judgeId, heatId, studentId])
}

// Open heat: thumbs up/down per judge × student × heat × category
model OpenThumb {
  id         Int              @id @default(autoincrement())
  judgeId    Int
  judge      Judge            @relation(fields: [judgeId], references: [id], onDelete: Cascade)
  heatId     Int
  heat       Heat             @relation(fields: [heatId], references: [id], onDelete: Cascade)
  studentId  Int
  student    Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  categoryId Int
  category   FeedbackCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  sentiment  String           // "up" | "down"

  @@unique([judgeId, heatId, studentId, categoryId])
}

// Open heat: optional free-text note per judge × student × heat
model OpenNote {
  id        Int     @id @default(autoincrement())
  judgeId   Int
  judge     Judge   @relation(fields: [judgeId], references: [id], onDelete: Cascade)
  heatId    Int
  heat      Heat    @relation(fields: [heatId], references: [id], onDelete: Cascade)
  studentId Int
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  note      String

  @@unique([judgeId, heatId, studentId])
}

// Competitive event: admin-set round type and sizes
model CompRound {
  id        Int   @id @default(autoincrement())
  eventId   Int   @unique
  event     Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  round     String  @default("final") // "final" | "semifinal"
  finalSize Int   @default(6)
  semiSize  Int   @default(7)
}

// Competitive final: numeric place per judge × event × leader student
model CompScore {
  id        Int     @id @default(autoincrement())
  judgeId   Int
  judge     Judge   @relation(fields: [judgeId], references: [id], onDelete: Cascade)
  eventId   Int
  event     Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  studentId Int     // the leader/representative student of the couple
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  place     Int

  @@unique([judgeId, eventId, studentId])
}

// Competitive semifinal: callback mark per judge × event × leader student
model SemiMark {
  id        Int     @id @default(autoincrement())
  judgeId   Int
  judge     Judge   @relation(fields: [judgeId], references: [id], onDelete: Cascade)
  eventId   Int
  event     Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  studentId Int
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  called    Boolean @default(false)

  @@unique([judgeId, eventId, studentId])
}
